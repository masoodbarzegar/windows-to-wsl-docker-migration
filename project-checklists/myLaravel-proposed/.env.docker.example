# Compose-level configuration for myLaravel (WSL migration).
# Copy this file to .env.docker and adjust values as needed:
#   cp .env.docker.example .env.docker
#
# This file only controls the Docker Compose layer (host ports, MySQL bootstrap
# credentials for local dev). It is separate from src/.env, which configures
# the Laravel application itself.
#
# All values below match this project's EXISTING defaults (preserving current
# behavior), not the generic template's defaults -- they are local-dev
# placeholders already visible in plaintext in the original docker-compose.yml,
# not real secrets.

# --- Host-facing ports -------------------------------------------------
# Defaults below match the original docker-compose.yml exactly.
WEB_HTTP_PORT=80
APP_FPM_PORT=9000
VITE_DEV_PORT=5174
PHPMYADMIN_PORT=8081

# NOTE: if you plan to run this alongside the already-migrated laravelLivewireAdmin
# WSL stack (tools profile default port 8081), change PHPMYADMIN_PORT here to
# avoid a collision, e.g.:
# PHPMYADMIN_PORT=8091

# Only relevant if you uncomment the optional `ports:` block under the `db`
# service in compose.yaml to publish MySQL directly to the host.
# DB_PORT=3306

# --- MySQL bootstrap credentials (local dev only) -----------------------
# These seed a NEW, empty database volume on first start. They do NOT restore
# the existing dbdata/ contents -- that is a separate, not-yet-approved
# restore step. Defaults below match the original docker-compose.yml exactly.
DB_ROOT_PASSWORD=root
DB_DATABASE=laravel
DB_USERNAME=laravel
DB_PASSWORD=secret
