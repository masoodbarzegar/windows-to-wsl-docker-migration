# Compose-level configuration for myLaravelReact (WSL migration).
# Copy to .env.docker per project and customize. Values below match this project's
# EXISTING defaults (preserving current behavior) -- local-dev placeholders, not secrets.

# --- Host-facing ports -------------------------------------------------
WEB_HTTP_PORT=80
APP_FPM_PORT=9000
VITE_DEV_PORT=5173
PHPMYADMIN_PORT=8081

# NOTE: change PHPMYADMIN_PORT if running alongside another migrated stack's tools profile
# simultaneously (e.g. myLaravel already defaults to 8081 too).
# PHPMYADMIN_PORT=8092

# Only relevant if you uncomment the optional `ports:` block under the `db` service.
# DB_PORT=3306

# --- MySQL bootstrap credentials (local dev only) -----------------------
DB_ROOT_PASSWORD=root
DB_DATABASE=laravel
DB_USERNAME=laravel
DB_PASSWORD=secret
