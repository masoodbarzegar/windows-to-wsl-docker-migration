# Compose-level configuration for myLaravelReactNew (WSL migration).
# Ports assigned proactively (per the operational lesson from myLaravelReact) to avoid
# collisions with the already-running laravelLivewireAdmin_wsl, myLaravel_wsl, and
# mylaravelreact_wsl stacks -- not the project's original defaults.

# --- Host-facing ports -------------------------------------------------
WEB_HTTP_PORT=8093
APP_FPM_PORT=9002
VITE_DEV_PORT=5176
PHPMYADMIN_PORT=8081

# --- MySQL bootstrap credentials (local dev only) -----------------------
DB_ROOT_PASSWORD=root
DB_DATABASE=laravel
DB_USERNAME=laravel
DB_PASSWORD=secret
