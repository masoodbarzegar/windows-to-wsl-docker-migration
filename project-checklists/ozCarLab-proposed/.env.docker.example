# Compose-level configuration for ozCarLab (WSL migration).
# Ports assigned proactively to avoid collisions with already-running WSL stacks
# (laravelLivewireAdmin_wsl, myLaravel_wsl, myLaravelReact_wsl, myLaravelReactNew_wsl).

# --- Host-facing ports -------------------------------------------------
WEB_HTTP_PORT=8094
PGADMIN_PORT=5050

# Only relevant if you uncomment the optional `ports:` block under the `db` service.
# DB_PORT=5432

# --- PostgreSQL bootstrap credentials (local dev only) -------------------
# Match the original docker-compose.yml's values exactly (preserving behavior).
DB_DATABASE=ozcar
DB_USERNAME=admin_new
DB_PASSWORD=123456

# --- pgAdmin ---------------------------------------------------------------
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin
