# Generic Docker Compose environment template for WSL migrations.
#
# Per project: copy this to .env.docker, fill in real (still-local-dev-only)
# values, and add .env.docker to that project's .gitignore. This .example
# file stays tracked in git; the real .env.docker never does.
#
# Every value below is a placeholder / safe local-dev default -- nothing here
# is a real secret. Compose does NOT auto-load a file named .env.docker the
# way it auto-loads a plain .env -- you must pass it explicitly:
#   docker compose --env-file .env.docker -f compose.yaml up -d

# --- Compose project identity -------------------------------------------
# REQUIRED, must be explicit and unique per project (COMPOSE-STANDARD.md, rule 5).
# Convention: <project-name>_wsl -- append _wsl specifically when an old
# Windows-side Compose project of the same logical name still exists, so the
# two can never collide.
COMPOSE_PROJECT_NAME=changeme_wsl

# --- Host-facing ports ----------------------------------------------------
# Change any of these if the default is already in use by another project
# you run concurrently.
APP_PORT=8080
# VITE_PORT=5173            # uncomment if the app service runs a Node/Vite dev server
PHPMYADMIN_PORT=8081        # only relevant if using compose.mysql-laravel.example.yaml with the tools profile
PGADMIN_PORT=8082           # only relevant if using compose.postgres-laravel.example.yaml with the tools profile
# DB_PORT=3306              # only relevant if you deliberately uncommented the db ports: block (rule 7)

# --- Database credentials (local dev only) --------------------------------
DB_DATABASE=app
DB_USERNAME=app
DB_PASSWORD=secret
DB_ROOT_PASSWORD=root       # MySQL only -- PostgreSQL has no separate root account

# --- pgAdmin (PostgreSQL template only) ------------------------------------
# PGADMIN_EMAIL=admin@example.com
# PGADMIN_PASSWORD=admin
